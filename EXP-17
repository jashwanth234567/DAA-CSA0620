def champagneTower(poured,row,glass):

    dp=[[0]*101 for _ in range(101)]
    dp[0][0]=poured

    for r in range(row+1):
        for c in range(r+1):

            overflow=max(0,dp[r][c]-1)/2

            dp[r+1][c]+=overflow
            dp[r+1][c+1]+=overflow

    return min(1,dp[row][glass])


print(champagneTower(2,1,1))
